{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],

    // ✅ JSX Support - This is what you were missing
    "jsx": "react-jsx",

    "resolveJsonModule": true,
    "declaration": false
  },
  "include": [
    "src/**/*"          // Includes all .ts and .tsx files in src/
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
