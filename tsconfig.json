{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // React JSX support
    "jsx": "react-jsx",

    // Vite + Node support
    "types": ["vite/client", "node"],
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": [
    "server.ts",           // Server file in root
    "src/**/*",            // All frontend code
    "vite.config.ts"       // Vite config
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
