{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // React + JSX support
    "jsx": "react-jsx",

    // Vite support
    "types": ["vite/client", "node"],
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": [
    "src/**/*",           // All your React + server code
    "vite.config.ts"      // Include vite.config.ts explicitly
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
